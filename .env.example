# ===========================
# CONFIGURAÇÃO DO SERVIDOR
# ===========================
NODE_ENV=development
API_PORT=3000
API_HOST=localhost

# ===========================
# COMFYUI LOCAL
# ===========================
COMFYUI_HOST=localhost
COMFYUI_PORT=8188
COMFYUI_TIMEOUT=300000

# ===========================
# AUTENTICAÇÃO
# ===========================
# Gere com: npm run generate-key
API_KEY=sk_live_your_secret_key_here_change_this

# ===========================
# ARMAZENAMENTO
# ===========================
STORAGE_PATH=./storage
UPLOAD_MAX_SIZE=10485760
CLEANUP_INTERVAL=86400000

# ===========================
# LOGGING
# ===========================
LOG_LEVEL=info

# ===========================
# RATE LIMITING
# ===========================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ===========================
# REDIS + BULLMQ (ETAPA 10)
# ===========================
# Host Redis
REDIS_HOST=localhost

# Porta Redis
REDIS_PORT=6379

# Password Redis (se houver)
REDIS_PASSWORD=

# Database Redis (0-15)
REDIS_DB=0

# Concurrency: máximo de jobs simultâneos
QUEUE_CONCURRENCY=1

# ===========================
# CLOUDFLARE TUNNEL
# ===========================
# URL pública via Cloudflare Tunnel
# Deixe vazio para usar localhost durante desenvolvimento
CLOUDFLARE_TUNNEL_URL=

# Seu domínio no Cloudflare (ex: api-comfyui.example.com)
CLOUDFLARE_DOMAIN=api-comfyui.example.com

# UUID do tunnel (obtido via: cloudflared tunnel create api-comfyui)
CLOUDFLARE_TUNNEL_UUID=
